{
  "name": "ofx-to-csv",
  "version": "0.1.0",
  "description": "Convert OFX/QBO bank statements to CSV. Zero-dependency TypeScript parser + CLI tool.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "ofx-to-csv": "./dist/cli.cjs"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ofx",
    "qbo",
    "csv",
    "bank-statement",
    "parser",
    "finance",
    "quickbooks",
    "typescript",
    "cli",
    "converter",
    "nodejs",
    "open-financial-exchange",
    "banking"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remotenodelabs/ofx-to-csv.git"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
